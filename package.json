{
  "name": "whisk",
  "version": "1.0.0",
  "type": "module",
  "description": "A personal recipe manager PWA — manage recipes, plan meals, build shopping lists, and use AI to discover new dishes.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/rsmedstad/whisk.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "bun run build && npx wrangler pages deploy dist --project-name whisk --branch main --commit-dirty=true",
    "setup": "node scripts/setup.js",
    "import-csv": "bun scripts/import-csv.ts"
  },
  "dependencies": {
    "nanoid": "^5.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "lighthouse": "^13.0.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "xlsx": "^0.18.5"
  }
}
